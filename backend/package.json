{
  "name": "cshq-api",
  "version": "1.0.0",
  "description": "CS HQ Backend API — Construct Scenery Limited",
  "main": "server.js",
  "scripts": {
    "start": "npm run migration:run && node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "typeorm": "typeorm-ts-node-commonjs --dataSource src/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:show": "npm run typeorm -- migration:show",
    "migration:generate": "npm run typeorm -- migration:generate src/migrations/",
    "db:encrypt-existing": "node db/migrate-encrypt.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 10000,
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "Controllers/**/*.js",
      "services/**/*.js",
      "!**/node_modules/**"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(uuid)/)"
    ],
    "moduleNameMapper": {
      "^uuid$": "<rootDir>/tests/__mocks__/uuid.js"
    }
  },
  "keywords": [
    "api",
    "express",
    "supabase",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/client-ses": "^3.1073.0",
    "@aws-sdk/client-sesv2": "^3.1073.0",
    "@types/node": "^25.9.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.0.3",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.9",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "ts-node": "^10.9.2",
    "typeorm": "^1.0.0",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "nodemon": "^3.0.0",
    "supertest": "^7.2.2"
  }
}
